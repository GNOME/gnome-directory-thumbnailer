#: ../src/main.c:383
#, c-format
msgid "Error generating thumbnail for file ‘%s’."
msgstr "Error dres ow dinythi byghan-aven rag restren ‘%s’."

#: ../src/main.c:388
#, c-format
msgid "Error generating thumbnail for file ‘%s’: recursion limit reached."
msgstr ""
"Error dres ow dinythi byghan-aven rag restren ‘%s’: finweth dasleverel "
"hedhys."

#: ../src/main.c:393
#, c-format
msgid ""
"Error generating thumbnail for file ‘%s’: MIME type ‘%s’ is unsupported."
msgstr ""
"Error dres ow dinythi byghan-aven rag restren ‘%s’: eghen MIME ‘%s’ yw "
"anskoodhys."

#. No error, but the directory was empty.
#: ../src/main.c:441
#, c-format
msgid "Directory is empty."
msgstr "Restrenva yw gwag."

#: ../src/main.c:499
msgid "Maximum size of the thumbnail in pixels (maximum width or height)"
msgstr "Braster moyha a'n byghan-aven yn pyksels (lester po ughelder moyha)"

#: ../src/main.c:500
msgid "Show the normal folder icon as an overlay on the thumbnail"
msgstr ""
"Diskwedhes an arwodhik restrenva normal avel unn gwiskas war'n byghan-aven"

#: ../src/main.c:501
msgid "[INPUT FILE] [OUTPUT FILE]"
msgstr "[RESTREN YNWORRANS] [RESTREN ESKORRANS]"

#. Handle the command line options.
#. Translators: This is the command line description of what the application does. Please keep the em-dash (or an equivalent).
#: ../src/main.c:537
msgid "— Generate thumbnails for directories"
msgstr "— Dinythi byghan-avenyow rag restrenvaow"

#: ../src/main.c:542
#, c-format
msgid "Couldn’t parse command line options: %s\n"
msgstr "Na yllir redya dewisyow arghadow-linen: %s\n"

#: ../src/main.c:579
#, c-format
msgid "Couldn’t generate thumbnail for directory ‘%s’: %s\n"
msgstr "Na yllir dinythi byghan-aven rag restrenva ‘%s’: %s\n"

#. Failed to load the icon. Shame.
#: ../src/main.c:677
#, c-format
msgid "Couldn’t load folder overlay icon: %s\n"
msgstr "Na yllir karga arwodhik gwiskas restrenva: %s\n"

#: ../src/main.c:700
#, c-format
msgid "Couldn’t save thumbnail to ‘%s’: %s\n"
msgstr "Na yllir sawya byghan-aven dhe ‘%s’: %s\n"
